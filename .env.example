# =============================================================================
# LunAcedia — Information infrastructure for the Lun ecosystem
# Copy this file to .env and fill in the values
# =============================================================================

# =============================================================================
# SERVER
# =============================================================================
# Port for the WebSocket server (clients connect here to receive JarvisEvents)
PORT=4000

# Bearer token for client authentication (leave empty to disable — LAN only)
# ACEDIA_SECRET=your-secret-here
ACEDIA_SECRET=

# =============================================================================
# GITHUB
# =============================================================================
GITHUB_ENABLED=false
# GITHUB_TOKEN=ghp_...
GITHUB_TOKEN=
# Repos to watch — "*" for all, or JSON array: '["owner/repo1", "owner/repo2"]'
GITHUB_WATCHED_REPOS=*
# Repos to exclude — JSON array: '["owner/noisy-repo"]'
GITHUB_EXCLUDE_REPOS=[]
# Poll interval in seconds (min 30)
GITHUB_POLL_INTERVAL_SEC=120

# =============================================================================
# EMAIL (future)
# =============================================================================
# GMAIL_ENABLED=false

# =============================================================================
# CALENDAR (future)
# =============================================================================
# GCAL_ENABLED=false

# =============================================================================
# RSS (future)
# =============================================================================
# RSS_ENABLED=false
# RSS_FEEDS='["https://hnrss.org/frontpage", "https://lobste.rs/rss"]'

# =============================================================================
# HOME ASSISTANT (future)
# =============================================================================
# HA_ENABLED=false
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=
