# =============================================================================
# LunAcedia — Information infrastructure for the Lun ecosystem
# Copy this file to .env and fill in the values
# =============================================================================

# =============================================================================
# SERVER
# =============================================================================
# Port for the WebSocket server (clients connect here to receive AcediaEvents)
PORT=4000

# Bearer token for client authentication (leave empty to disable — LAN only)
# ACEDIA_SECRET=your-secret-here
ACEDIA_SECRET=

# =============================================================================
# GITHUB
# =============================================================================
GITHUB_ENABLED=false
# GITHUB_TOKEN=ghp_...
GITHUB_TOKEN=
# Repos to watch — "*" for all, or JSON array: '["owner/repo1", "owner/repo2"]'
GITHUB_WATCHED_REPOS=*
# Repos to exclude — JSON array: '["owner/noisy-repo"]'
GITHUB_EXCLUDE_REPOS=[]
# Poll interval in seconds (min 30)
GITHUB_POLL_INTERVAL_SEC=120

# =============================================================================
# EMAIL — Gmail via OAuth2
# =============================================================================
GMAIL_ENABLED=false
# OAuth2 credentials — create at https://console.cloud.google.com/
# Scopes required: https://www.googleapis.com/auth/gmail.readonly
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Get a refresh token via: https://developers.google.com/oauthplayground
GMAIL_REFRESH_TOKEN=
# Only surface messages newer than N hours (default 24)
GMAIL_MAX_AGE_HOURS=24
# Poll interval in minutes (min 2, default 5)
GMAIL_POLL_INTERVAL_MIN=5
# Priority rules — first match wins, falls back to "info"
# JSON array of {senderPattern, priority, label?}
# senderPattern = case-insensitive substring match against "From Subject"
# GMAIL_RULES='[{"senderPattern":"boss@corp.com","priority":"urgent"},{"senderPattern":"@corp.com","priority":"normal"},{"senderPattern":"newsletter","priority":"info"}]'
GMAIL_RULES=[]

# =============================================================================
# CALENDAR (future)
# =============================================================================
# GCAL_ENABLED=false

# =============================================================================
# RSS
# =============================================================================
RSS_ENABLED=false
# Simple array of URLs (all info priority):
# RSS_FEEDS='["https://hnrss.org/frontpage", "https://lobste.rs/rss"]'
# Rich config (per-feed label + priority):
# RSS_FEEDS='[{"url":"https://hnrss.org/frontpage","label":"HN","priority":"info"},{"url":"https://lobste.rs/rss","label":"Lobsters"}]'
RSS_FEEDS=[]
# Only surface items newer than N hours (default 24 — prevents flooding on first run)
RSS_MAX_AGE_HOURS=24
# Poll interval in minutes (min 5, default 30)
RSS_POLL_INTERVAL_MIN=30

# =============================================================================
# HOME ASSISTANT (future)
# =============================================================================
# HA_ENABLED=false
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=