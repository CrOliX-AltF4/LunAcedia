# =============================================================================
# LunAcedia — Information infrastructure for the Lun ecosystem
# Copy this file to .env and fill in the values
# =============================================================================

# =============================================================================
# SERVER
# =============================================================================
PORT=4000
HTTP_PORT=4001

# Bearer token for client authentication (leave empty to disable — LAN only)
ACEDIA_SECRET=

# =============================================================================
# AI BUTLER (optional)
# =============================================================================
# AI_PROVIDER: none (default) | openai | ollama | natsume
AI_PROVIDER=none

# openai — requires OPENAI_API_KEY
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini

# ollama — local LLM
# OLLAMA_URL=http://localhost:11434
# AI_MODEL=llama3.2

# natsume — delegate to Natsume Core /api/core/synthesize
# NATSUME_CORE_URL=http://nas-ip:3333
# NATSUME_CORE_SECRET=<same as Natsume ADMIN_SECRET>

# =============================================================================
# PUSH NOTIFICATIONS — Firebase Cloud Messaging (optional)
# =============================================================================
# FIREBASE_PROJECT_ID=your-firebase-project
# FIREBASE_SERVICE_ACCOUNT_KEY=<base64 of service account JSON>
# Priority levels that trigger FCM push (comma-separated: urgent,normal,info)
# ACEDIA_FCM_FILTER=urgent,normal

# =============================================================================
# GITHUB
# =============================================================================
GITHUB_ENABLED=false
GITHUB_TOKEN=
GITHUB_WATCHED_REPOS=*
GITHUB_EXCLUDE_REPOS=[]
GITHUB_POLL_INTERVAL_SEC=120

# =============================================================================
# EMAIL — Gmail via OAuth2
# =============================================================================
GMAIL_ENABLED=false
# OAuth2 credentials — https://console.cloud.google.com/ — scope: gmail.readonly
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Refresh token — https://developers.google.com/oauthplayground
GMAIL_REFRESH_TOKEN=
GMAIL_MAX_AGE_HOURS=24
GMAIL_POLL_INTERVAL_MIN=5
# Priority rules — first match wins — senderPattern = case-insensitive substring of "From Subject"
# GMAIL_RULES='[{"senderPattern":"boss@corp.com","priority":"urgent"},{"senderPattern":"@corp.com","priority":"normal"},{"senderPattern":"newsletter","priority":"info"}]'
GMAIL_RULES=[]

# =============================================================================
# CALENDAR — Google Calendar via OAuth2
# =============================================================================
GCAL_ENABLED=false
# Same OAuth2 app as Gmail — add scope: https://www.googleapis.com/auth/calendar.readonly
GCAL_CLIENT_ID=
GCAL_CLIENT_SECRET=
GCAL_REFRESH_TOKEN=
# Calendars to poll — JSON array of calendar IDs (default: primary)
# GCAL_CALENDARS='["primary","work@group.calendar.google.com"]'
GCAL_CALENDARS=["primary"]
# How far ahead to fetch upcoming events (hours)
GCAL_LOOKAHEAD_HOURS=24
GCAL_POLL_INTERVAL_MIN=15
# Default priority for all calendar events (urgent|normal|info)
GCAL_PRIORITY=normal

# =============================================================================
# TASKS — Google Tasks via OAuth2
# =============================================================================
GTASKS_ENABLED=false
# Same OAuth2 app as Gmail/GCal — add scope: https://www.googleapis.com/auth/tasks.readonly
GTASKS_CLIENT_ID=
GTASKS_CLIENT_SECRET=
GTASKS_REFRESH_TOKEN=
# Task list to poll — "@default" for primary list
GTASKS_LIST_ID=@default
# Poll interval in minutes (min 5, default 15)
GTASKS_POLL_INTERVAL_MIN=15

# =============================================================================
# RSS
# =============================================================================
RSS_ENABLED=false
# FEEDS — simple URL array or rich config with label + priority
# RSS_FEEDS='["https://hnrss.org/frontpage", "https://lobste.rs/rss"]'
# RSS_FEEDS='[{"url":"https://hnrss.org/frontpage","label":"HN","priority":"info"}]'
RSS_FEEDS=[]
RSS_MAX_AGE_HOURS=24
RSS_POLL_INTERVAL_MIN=30

# =============================================================================
# HOME ASSISTANT (future)
# =============================================================================
# HA_ENABLED=false
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=